# =============================================================================
# .env.example — copy to .env and fill in. `.env` is gitignored (never commit
# secrets). The Databricks CLI auto-detects these vars for OAuth M2M auth.
#
#   cp .env.example .env && edit .env
#   set -a && source .env && set +a      # export into your shell
# =============================================================================

# Azure Databricks workspace URL (replace with your real workspace host).
DATABRICKS_HOST=https://adb-7405618019865738.18.azuredatabricks.net

# OAuth machine-to-machine (M2M) credentials for LOCAL runs only. Leave blank to
# instead use interactive `databricks auth login` (recommended for humans).
# NOTE: CI/CD does NOT use a secret — GitHub Actions authenticates via Workload
# Identity Federation (GitHub OIDC). See docs/cicd.md §4. WIF can't run locally,
# so local automation still uses these or `auth login`.
DATABRICKS_CLIENT_ID=
DATABRICKS_CLIENT_SECRET=

# Service-principal application id the bundle runs qa/prod jobs as
# (maps to var.deploy_service_principal in databricks.yml). Dev runs as you.
DATABRICKS_BUNDLE_VAR_deploy_service_principal=
